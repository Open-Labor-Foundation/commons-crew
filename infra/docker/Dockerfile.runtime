# Self-contained, droppable commons-crew runtime.
#
# One container: the chat runtime + materialization + governance, a file-backed
# state store (no external Postgres), the catalog fetched live from
# labor-commons main (never bundled), and inference via a user-supplied API key.
# This is the image that goes in ghcr.io and drops into any host — a VPS, a
# homelab app store, a PaaS one-click, or a Featherless-style runtime slot.
#
# Run it:
#   docker run -p 8080:8080 \
#     -e PA_PROVIDER_API_KEY=<your inference key> \
#     -e PA_PROVIDER_BASE_URL=https://api.featherless.ai/v1 \
#     -e PA_PROVIDER_MODEL=Qwen/Qwen3-32B \
#     -v crew-data:/app/.data \
#     ghcr.io/open-labor-foundation/commons-crew:latest
#
# The only required runtime input is the inference key (BYO — yours or the
# user's); everything else has a sane default below.

FROM node:20-alpine

# git: used at boot to mirror the catalog from labor-commons main.
RUN apk add --no-cache git

WORKDIR /app

# App code + commons-crew's OWN bundled agent/governance. Note: the
# labor-commons specialist catalog is deliberately NOT copied here — it is a
# live link fetched at boot (see CATALOG_* below). Copy the whole workspace
# before install so npm can resolve the monorepo workspaces.
COPY package.json package-lock.json tsconfig.json ./
COPY apps ./apps
COPY packages ./packages
COPY governance ./governance
COPY catalog ./catalog

# Install deps (tsx is a dev dependency and the runtime is tsx-executed, so we
# keep dev deps — do not set NODE_ENV=production before this).
RUN npm ci

# Self-contained profile: file-backed state store, no external database.
ENV PA_CONFIG_PROFILE=local
ENV PA_API_PORT=8080

# Persistent runtime state (mount a volume at /app/.data to keep it).
ENV PA_STATE_FILE=/app/.data/state.json
ENV PA_ARTIFACTS_ROOT=/app/.data/artifacts
ENV PA_BACKUPS_ROOT=/app/.data/backups

# Catalog = live link to labor-commons main, mirrored at boot into OLF_AGENTS_ROOT.
ENV CATALOG_AUTO_SYNC=1
ENV OLF_AGENTS_ROOT=/app/.data/catalog
ENV CATALOG_REPO_URL=https://github.com/Open-Labor-Foundation/labor-commons.git
ENV CATALOG_REF=main

# Inference (BYO key). Supply PA_PROVIDER_API_KEY at run time; the others have
# defaults you can override.
ENV PA_PROVIDER_BASE_URL=https://api.featherless.ai/v1
ENV PA_PROVIDER_MODEL=Qwen/Qwen3-32B

EXPOSE 8080

CMD ["npm", "run", "start", "--workspace", "@commons-crew/crew-api"]
