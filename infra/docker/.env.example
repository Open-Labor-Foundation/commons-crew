# PostgreSQL
POSTGRES_DB=commons_crew
POSTGRES_USER=commons_crew
POSTGRES_PASSWORD=your-postgres-password

# Absolute path to your local labor-commons checkout on the host
LABOR_COMMONS_HOST_PATH=/absolute/path/to/labor-commons

# Application database
PA_DATABASE_URL=postgresql://commons_crew:your-postgres-password@postgres:5432/commons_crew

# Provider — set to your preferred OpenAI-compatible API
# Default: Featherless (api.featherless.ai/v1), Model: Qwen/Qwen3-32B
PA_PROVIDER_API_KEY=your-api-key-here
# PA_PROVIDER_BASE_URL=https://api.featherless.ai/v1
# PA_PROVIDER_MODEL=Qwen/Qwen3-32B

# Required — the crew-api port is published on the host network. This token
# gates every request except /health; clients must send it as
# `Authorization: Bearer <token>`. Generate one with `openssl rand -hex 32`.
PA_API_TOKEN=your-generated-token-here
